# Copy to vercel_app/.env for local development.
# On the VPS, the deploy workflow writes ~/8bit-site/.env for docker-compose.prod.yml.

# Django
PROJECT_SECRET=change-me-to-a-long-random-string

# Postgres (used by db service and web service)
POSTGRES_DB=8bit
POSTGRES_USER=8bit
POSTGRES_PASSWORD=change-me

# Django database connection (web service overrides HOST to "db" in compose)
DATABASE_HOST=db
DATABASE_NAME=8bit
DATABASE_USER=8bit
DATABASE_PASSWORD=change-me

# Production only — comma-separated extra ALLOWED_HOSTS (e.g. server IP or domain)
ALLOWED_HOSTS_EXTRA=

# --- One-time Supabase migration (scripts/migrate_from_supabase.sh) ---
# SUPABASE_DATABASE_HOST=aws-0-us-west-1.pooler.supabase.com
# SUPABASE_DATABASE_USER=postgres.your-project-ref
# SUPABASE_DATABASE_PASSWORD=your-supabase-password
# SUPABASE_DATABASE_NAME=postgres
